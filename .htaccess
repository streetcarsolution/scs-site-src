# =========================================================
# OVH / Apache 2.4 - .htaccess propre et compatible
# =========================================================

# 1) Réécritures
RewriteEngine On

# ⚠️ Laisser passer les challenges Let's Encrypt
RewriteRule ^\.well-known/ - [L]

# Bloquer tout fichier/dossier "caché" (.git, .env, .ht*, etc.)
# ...sauf .well-known (juste au-dessus)
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule "(^|/)\." - [F]

# Canonique + HTTPS en une redirection (choix: sans "www")
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.streetcarsolution\.com$ [NC]
RewriteRule ^ https://streetcarsolution.com%{REQUEST_URI} [L,R=301]

# 2) Caching long sur les assets
<IfModule mod_headers.c>
  <FilesMatch "(?i)\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|ttf|woff|woff2|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # 3) Petites en-têtes de sécurité
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # HSTS seulement en HTTPS
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# 4) Compression (si dispo côté OVH)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html tex
