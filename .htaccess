# ===========================
#  .htaccess – StreetCarSolution
#  (placer ce fichier dans /www)
# ===========================

RewriteEngine On

# Bloquer fichiers/dossiers cachés (.git, .env, .ht*, etc.)
# …mais laisser passer .well-known pour Let's Encrypt
RewriteRule "(^|/)\.(?!well-known/)" - [F]

<IfModule mod_alias.c>
  RedirectMatch 404 ^/\.git
  RedirectMatch 404 ^/\.hg
  RedirectMatch 404 ^/\.svn
</IfModule>

# Canonique : HTTPS + WWW (hors ACME)
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/ [NC]
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.streetcarsolution\.com$ [NC]
RewriteRule ^ https://www.streetcarsolution.com%{REQUEST_URI} [L,R=301]

<IfModule mod_headers.c>
  # Cache long pour assets (1 an)
  <FilesMatch "(?i)\.(css|js|png|jpe?g|gif|webp|svg|ico|ttf|woff|woff2|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML non mis en cache
  <FilesMatch "(?i)\.(html?)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Sécurité
  Header always set X-Content-Type-O
